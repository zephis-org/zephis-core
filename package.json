{
  "name": "@zephis/core",
  "version": "0.1.0",
  "description": "ZEPHIS Protocol - Zero Exposure Proof Handling Isolated Sessions Core Library",
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "scripts": {
    "build": "tsc",
    "dev": "tsc --watch",
    "test": "vitest",
    "test:coverage": "vitest --coverage",
    "lint": "eslint src/**/*.ts",
    "typecheck": "tsc --noEmit",
    "format": "prettier --write src/**/*.ts"
  },
  "keywords": [
    "zk",
    "tls",
    "proof",
    "blockchain",
    "privacy",
    "cryptography"
  ],
  "author": "ZEPHIS Protocol",
  "license": "MIT",
  "dependencies": {
    "bn.js": "^5.2.1",
    "node-forge": "^1.3.1",
    "snarkjs": "^0.7.4",
    "viem": "^2.21.32"
  },
  "devDependencies": {
    "@types/bn.js": "^5.1.5",
    "@types/node": "^22.5.4",
    "@types/node-forge": "^1.3.11",
    "@types/snarkjs": "^0.7.8",
    "@typescript-eslint/eslint-plugin": "^8.4.0",
    "@typescript-eslint/parser": "^8.4.0",
    "@vitest/coverage-v8": "^2.0.5",
    "c8": "^10.1.2",
    "eslint": "^9.9.1",
    "prettier": "^3.3.3",
    "typescript": "^5.6.2",
    "vitest": "^2.0.5"
  },
  "files": [
    "dist",
    "README.md"
  ],
  "repository": {
    "type": "git",
    "url": "https://github.com/zephis-org/zephis-core.git"
  },
  "engines": {
    "node": ">=18.0.0"
  }
}
